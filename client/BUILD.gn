import("//testing/test.gni")

source_set("client") {
  configs += [ "//third_party/owl/bridge:owl_objc_visibility" ]
  sources = [
    "OWLAIChatSession.h",
    "OWLAIChatSession.mm",
    "OWLAIMessage.h",
    "OWLAIMessage.mm",
    "OWLAddressBarController.h",
    "OWLAddressBarController.mm",
    "OWLAgentSession.h",
    "OWLAgentSession.mm",
    "OWLBrowserMemory.h",
    "OWLBrowserMemory.mm",
    "OWLInputTranslator.h",
    "OWLInputTranslator.mm",
    "OWLShortcutManager.h",
    "OWLShortcutManager.mm",
    "OWLTab.h",
    "OWLTab.mm",
    "OWLTabManager.h",
    "OWLTabManager.mm",
    "OWLWebContentView.h",
    "OWLWebContentView.mm",
  ]

  frameworks = [
