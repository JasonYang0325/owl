    "//base/test:test_support",
    "//mojo/core/embedder",
    "//mojo/public/cpp/bindings",
    "//mojo/public/cpp/system",
    "//testing/gtest",
    "//third_party/owl/bridge",
    "//third_party/owl/bridge:owl_bridge_c_api",
    "//third_party/owl/bridge:mojo_thread",
    "//third_party/owl/host:host_content",
    "//third_party/owl/mojom",
  ]

  frameworks = [
    "AppKit.framework",
    "QuartzCore.framework",
  ]
}
