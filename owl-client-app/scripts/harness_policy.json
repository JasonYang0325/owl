  "suites": {
    "cpp_host": {
      "kind": "gtest",
      "required": true,
      "timeout_sec": 300,
      "retries": 0,
      "stability_runs": 1,
      "min_discovered_cases": 1,
      "max_not_run_cases": 0,
      "build_targets": [
        "owl_host_unittests"
      ],
      "binary": "$BUILD_DIR/owl_host_unittests",
      "failure_hints": [
        "Run `autoninja -C out/owl-host owl_host_unittests` and inspect linker/compiler errors.",
        "If binary runs but tests fail, rerun with `--gtest_filter=<Suite>.<Case>` to isolate."
      ]
    },
    "cpp_client": {
      "kind": "gtest",
      "required": true,
      "timeout_sec": 300,
      "retries": 0,
      "stability_runs": 1,
      "min_discovered_cases": 1,
      "max_not_run_cases": 0,
      "build_targets": [
        "owl_client_unittests"
      ],
      "binary": "$BUILD_DIR/owl_client_unittests",
      "failure_hints": [
        "Run `autoninja -C out/owl-host owl_client_unittests` and inspect compiler/linker errors.",
        "If binary runs but tests fail, rerun with `--gtest_filter=<Suite>.<Case>` to isolate."
      ]
    },
    "swift_unit": {
      "kind": "swift",
      "required": true,
      "timeout_sec": 240,
      "retries": 0,
      "stability_runs": 1,
      "min_discovered_cases": 100,
      "max_not_run_cases": 0,
      "filter": "OWLUnitTests",
      "failure_hints": [
        "Run `swift test --filter OWLUnitTests` to inspect first failing unit test.",
        "Do not accept flaky unit tests; keep this suite deterministic."
      ]
    },
    "swift_integration": {
      "kind": "swift",
      "required": true,
      "timeout_sec": 240,
      "retries": 1,
      "stability_runs": 2,
      "min_discovered_cases": 8,
      "max_not_run_cases": 0,
      "filter": "OWLIntegrationTests.OWLIntegrationTests",
      "requires_host_binary": true,
      "build_targets": [
        "third_party/owl/bridge:OWLBridge"
      ],
      "failure_hints": [
        "Verify host exists at `out/owl-host/OWL Host.app/.../OWL Host` or `out/owl-host/owl_host`.",
        "Keep integration cases local/deterministic (data URL or local fixture only)."
      ]
    },
    "swift_pipeline": {
      "kind": "swift",
      "required": true,
      "timeout_sec": 300,
      "retries": 1,
      "stability_runs": 2,
      "min_discovered_cases": 30,
      "max_not_run_cases": 0,
      "filter": "OWLBrowserTests.OWLBrowserTests",
      "requires_host_binary": true,
      "build_targets": [
        "third_party/owl/bridge:OWLBridge"
      ],
      "failure_hints": [
        "Do not add external-network dependency to pipeline tests.",
        "If a case fails once then passes on retry, treat as flake and fix before merging."
      ]
    },
    "cli_nightly": {
      "kind": "script",
      "required": false,
      "timeout_sec": 900,
      "retries": 0,
      "stability_runs": 1,
      "min_discovered_cases": 1,
      "max_not_run_cases": 0,
      "fixed_cases": [
        "NightlyCLI/testRunTestsCli"
      ],
      "command": [
        "$SCRIPT_DIR/run_tests.sh",
        "cli"
      ],
      "treat_skip_as_skipped": true,
      "skip_patterns": [
        "SKIP"
      ],
      "failure_hints": [
        "Ensure OWL Browser + OWLCLI preconditions are met before running nightly CLI suite.",
        "If this suite is frequently skipped, promote deterministic app bootstrap inside the script command."
      ]
    },
    "cli_release": {
      "kind": "script",
      "required": true,
      "timeout_sec": 900,
      "retries": 0,
      "stability_runs": 1,
      "min_discovered_cases": 1,
      "max_not_run_cases": 0,
      "fixed_cases": [
        "ReleaseCLI/testRunTestsCliStrict"
      ],
      "command": [
        "$SCRIPT_DIR/run_tests_strict_release.sh",
        "cli"
      ],
      "failure_hints": [
        "Release gate requires CLI suite to execute real cases; skipped/0-case runs are hard failures.",
        "Verify OWLCLI build artifact and browser bootstrap before running release-gate."
      ]
    },
    "xcuitest_nightly": {
      "kind": "script",
      "required": false,
      "timeout_sec": 1800,
      "retries": 0,
      "stability_runs": 1,
      "min_discovered_cases": 1,
      "max_not_run_cases": 0,
      "fixed_cases": [
        "NightlyXCUITest/testRunTestsXCUITest"
      ],
      "command": [
        "$SCRIPT_DIR/run_tests.sh",
        "xcuitest"
      ],
      "treat_skip_as_skipped": true,
      "skip_patterns": [
        "SKIP",
        "no signing identity"
      ],
      "failure_hints": [
        "XCUITest suite requires signing + GUI. Keep this suite optional until infra is guaranteed in nightly runner.",
        "If compile fails, inspect /tmp/owl_xcuitest_logs/latest_full.log and latest_diagnostic.log."
      ]
    },
    "xcuitest_release": {
      "kind": "script",
      "required": true,
      "timeout_sec": 1800,
      "retries": 0,
      "stability_runs": 1,
      "min_discovered_cases": 1,
      "max_not_run_cases": 0,
      "fixed_cases": [
        "ReleaseXCUITest/testRunTestsXCUITestStrict"
      ],
      "command": [
        "$SCRIPT_DIR/run_tests_strict_release.sh",
        "xcuitest"
      ],
      "failure_hints": [
        "Release gate requires signed GUI-capable runner; any skip/0-case XCUITest run fails immediately.",
        "If compile/runtime fails, inspect /tmp/owl_xcuitest_logs/latest_full.log and latest_diagnostic.log."
      ]
    },
    "dual_e2e_nightly": {
      "kind": "script",
      "required": false,
      "timeout_sec": 2400,
      "retries": 0,
      "stability_runs": 1,
      "min_discovered_cases": 1,
      "max_not_run_cases": 0,
      "fixed_cases": [
        "NightlyDualE2E/testRunTestsDualE2E"
      ],
      "command": [
        "$SCRIPT_DIR/run_tests.sh",
        "dual-e2e"
      ],
      "treat_skip_as_skipped": true,
      "skip_patterns": [
        "SKIP",
        "playwright directory not found",
        "no signing identity"
      ],
      "failure_hints": [
        "Dual-driver suite needs Playwright assets, CDP port, and XCUITest signing.",
        "Use this suite to observe cross-layer regressions that are invisible in non-GUI deterministic gates."
      ]
    }
  },
  "use_cases": {
    "cpp_host_smoke": {
      "description": "Required C++ host suite discovers and executes at least one test case.",
      "required": true,
      "domains": [
        "platform-core"
      ],
      "selector_mode": "all",
      "selectors": [
        {
          "suite": "cpp_host",
          "case_regex": ".*",
          "min_matches": 1,
          "min_passed": 1
        }
      ]
    },
    "cpp_client_smoke": {
      "description": "Required C++ client suite discovers and executes at least one test case.",
      "required": true,
